# ── WhatsApp Bot Configuration ────────────────────────────
# Copy this file to .env and fill in your values

# ── Bot Settings ──────────────────────────────────────────
BOT_NAME=Iris
BOT_PREFIX=!
OWNER_NUMBER=0612345678

# ── Group JID for scheduled games ─────────────────────────
# Format: "120363XXX-XXXX@g.us"
GROUP_JID=

# ── Database ──────────────────────────────────────────────
DB_PATH=./src/db/iris.db

# ── API Keys (if using weather, news, or other APIs) ──────
WEATHER_API_KEY=
NEWS_API_KEY=

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=info
DEBUG=false

# ── Features ──────────────────────────────────────────────
ENABLE_GAMES=true
ENABLE_AI=true
ENABLE_MODERATION=true
ENABLE_ECONOMY=true
